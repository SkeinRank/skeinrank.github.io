    gap: 0.6rem;
    align-items: center;
    margin-bottom: 1rem;
    color: #67e8f9;
  }

  .sr-command-line code {
    border: 0 !important;
    padding: 0 !important;
    color: #e0f2fe !important;
    background: transparent !important;
    font: inherit;
  }

  .sr-trace-code code {
    border: 0 !important;
    padding: 0 !important;
    color: inherit;
    background: transparent !important;
    font: inherit;
  }

  .sr-demo-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 0.8rem;
    margin: 0 0 1rem;
  }

  .sr-demo-pane {
    min-height: 6.4rem;
    padding: 0.9rem;
    border: 1px solid var(--sr-border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sr-card-soft) 72%, transparent);
  }

  .sr-demo-pane strong {
    display: block;
    margin-top: 0.55rem;
    color: var(--sr-text);
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
