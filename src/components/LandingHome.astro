    border-radius: var(--sr-radius-lg);
    background:
      radial-gradient(circle at 10% 20%, color-mix(in srgb, var(--sr-accent) 16%, transparent), transparent 30%),
      linear-gradient(135deg, var(--sr-surface), color-mix(in srgb, var(--sr-card-soft) 70%, transparent));
  }

  .sr-inline-link {
    display: inline-flex;
    margin-top: 1.1rem;
    color: var(--sr-cyan);
    font-weight: 900;
    text-decoration: none;
  }

  .sr-inline-link:hover {
    text-decoration: underline;
  }

  .sr-dashboard-card {
    overflow: hidden;
    padding: 0.95rem;
  }

  .sr-console-preview {
    position: relative;
    gap: 1.35rem;
    padding: clamp(1.15rem, 3vw, 1.65rem);
    overflow: hidden;
    border: 1px solid var(--sr-border);
    border-radius: var(--sr-radius-lg);
    background:
      radial-gradient(circle at 14% 0%, color-mix(in srgb, var(--sr-cyan) 16%, transparent), transparent 22rem),
      radial-gradient(circle at 86% 2%, color-mix(in srgb, var(--sr-accent) 18%, transparent), transparent 24rem),
      linear-gradient(145deg, color-mix(in srgb, var(--sr-card-soft) 70%, transparent), color-mix(in srgb, var(--sr-surface-strong) 86%, transparent));
    box-shadow: var(--sr-shadow);
  }

  .sr-preview-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(17rem, 0.55fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: end;
  }

  .sr-preview-heading .sr-section-label {
    grid-column: 1 / -1;
    margin-bottom: -0.1rem;
  }

  .sr-preview-heading h2 {
    max-width: 13ch;
  }

  .sr-preview-heading p:not(.sr-section-label) {
    margin: 0;
    color: var(--sr-text-soft);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .sr-preview-stage {
    display: grid;
    gap: 1rem;
  }

  .sr-preview-mobile-proof {
    display: none;
  }

  .sr-preview-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sr-border-strong) 84%, transparent);
    border-radius: 1.45rem;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(2, 6, 23, 0.92));
    box-shadow:
      0 28px 90px rgba(2, 6, 23, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .sr-preview-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 14%),
      radial-gradient(circle at 88% 4%, rgba(139, 92, 246, 0.14), transparent 18rem);
  }

  .sr-preview-toolbar {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.42rem;
    min-height: 2.35rem;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(2, 6, 23, 0.72);
  }

  .sr-preview-toolbar span {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.45);
  }

  .sr-preview-toolbar span:first-child {
    background: #ef4444;
  }

  .sr-preview-toolbar span:nth-child(2) {
    background: #f59e0b;
  }

  .sr-preview-toolbar span:nth-child(3) {
    background: #22c55e;
  }

  .sr-preview-toolbar strong {
    margin-inline-start: 0.45rem;
    color: rgba(226, 232, 240, 0.8);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.02em;
  }

  .sr-preview-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top left;
  }

  .sr-preview-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .sr-preview-proof-grid article {
    padding: 1rem;
    border: 1px solid var(--sr-border);
    border-radius: 1.1rem;
    background: color-mix(in srgb, var(--sr-card) 78%, transparent);
  }

  .sr-preview-proof-grid span {
    display: inline-flex;
    margin-bottom: 0.55rem;
    color: var(--sr-cyan);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sr-preview-proof-grid strong {
    display: block;
    color: var(--sr-text);
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .sr-preview-proof-grid p {
    margin: 0.5rem 0 0;
    color: var(--sr-text-soft);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .sr-preview-proof-grid code {
    color: var(--sr-cyan);
  }

  .sr-preview-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .sr-dashboard-head,
  .sr-dashboard-row,
  .sr-dashboard-footer {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr 0.8fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem;
    border-bottom: 1px solid var(--sr-border);
  }

  .sr-dashboard-head {
    grid-template-columns: 1fr;
    border-radius: 0.95rem;
    background: var(--sr-card-soft);
  }

  .sr-dashboard-head span,
  .sr-dashboard-row span {
    color: var(--sr-muted);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .sr-dashboard-head strong,
  .sr-dashboard-row strong {
    color: var(--sr-text);
  }

  .sr-dashboard-row em {
    justify-self: end;
    color: var(--sr-cyan);
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 850;
  }

  .sr-dashboard-footer {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-bottom: 0;
    color: var(--sr-muted);
    font-size: 0.78rem;
  }

  .sr-status-table {
    overflow: hidden;
  }

  .sr-status-row {
    display: grid;
    grid-template-columns: 0.8fr 0.55fr 1.65fr;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--sr-border);
  }

  .sr-status-row:last-child {
    border-bottom: 0;
  }

  .sr-status-row span {
    color: var(--sr-text-soft);
  }

  .sr-status-row span:first-child {
    color: var(--sr-text);
    font-weight: 850;
  }

  .sr-status-row-head {
    background: var(--sr-card-soft);
  }

  .sr-status-row-head span {
    color: var(--sr-muted) !important;
    font-size: 0.76rem;
    font-weight: 950;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-status-row mark {
    margin: 0;
  }

  .sr-cta {
    padding: clamp(1.5rem, 4vw, 2rem);
  }

  @media (max-width: 1180px) {
    .sr-hero-block,
    .sr-dashboard-section,
    .sr-cta {
      grid-template-columns: 1fr;
    }

    .sr-hero-copy h1 {
      max-width: 16ch;
    }

    .sr-hero-visual {
      min-height: auto;
    }

    .sr-terminal-card {
      transform: none;
    }

    .sr-floating-card {
      position: static;
      display: inline-block;
      margin: 0.8rem 0.5rem 0 0;
    }

    .sr-pipeline-v2,
    .sr-feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }


    .sr-preview-heading {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .sr-preview-heading h2 {
      max-width: 17ch;
    }

    .sr-preview-proof-grid {
      grid-template-columns: 1fr;
    }

    .sr-feature-primary {
      grid-row: auto;
    }
  }

  @media (max-width: 760px) {
    .sr-hero-block {
      padding: 1.25rem;
      border-radius: 1.5rem;
    }

    .sr-metrics,
    .sr-demo-grid,
    .sr-language-brief-grid,
    .sr-pipeline-v2,
    .sr-feature-grid,
    .sr-dashboard-footer {
      grid-template-columns: 1fr;
    }

    .sr-status-row,
    .sr-dashboard-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      align-items: start;
    }

    .sr-dashboard-row em {
      justify-self: start;
    }
  }
  /* Cinematic terminology-control hero. */
  .sr-hero-core {
    grid-template-columns: minmax(21rem, 0.84fr) minmax(34rem, 1.16fr);
    min-height: min(72vh, 48rem);
    padding: clamp(2rem, 5vw, 4.6rem);
    background:
      radial-gradient(circle at 18% 20%, rgba(34, 211, 238, 0.17), transparent 29%),
      radial-gradient(circle at 78% 16%, rgba(139, 92, 246, 0.25), transparent 34%),
      radial-gradient(circle at 56% 82%, rgba(34, 197, 94, 0.10), transparent 32%),
      linear-gradient(135deg, rgba(2, 6, 23, 0.98), rgba(15, 23, 42, 0.86));
  }

  .sr-hero-core::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px);
    background-size: 3.2rem 3.2rem;
    mask-image: radial-gradient(circle at 64% 48%, black 0%, transparent 62%);
    opacity: 0.42;
  }

  :global(:root[data-theme='light']) .sr-hero-core {
    background:
      radial-gradient(circle at 18% 20%, rgba(14, 165, 233, 0.18), transparent 30%),
      radial-gradient(circle at 78% 16%, rgba(109, 40, 217, 0.18), transparent 34%),
      radial-gradient(circle at 56% 82%, rgba(22, 163, 74, 0.10), transparent 32%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 249, 0.92));
  }

  .sr-hero-copy-core h1 {
    max-width: 19ch;
    font-size: clamp(2.3rem, 4.4vw, 4.1rem);
  }

  .sr-core-metrics div {
    backdrop-filter: blur(18px);
  }

  .sr-core-visual {
    position: relative;
    min-height: clamp(33rem, 42vw, 42rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sr-border) 92%, transparent);
    border-radius: 2rem;
    background:
      radial-gradient(circle at 50% 50%, rgba(34, 211, 238, 0.13), transparent 24%),
      radial-gradient(circle at 70% 30%, rgba(139, 92, 246, 0.16), transparent 32%),
      linear-gradient(145deg, rgba(2, 6, 23, 0.42), rgba(15, 23, 42, 0.58));
    box-shadow:
      0 28px 90px rgba(2, 6, 23, 0.26),
      inset 0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  :global(:root[data-theme='light']) .sr-core-visual {
    background:
      radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.12), transparent 24%),
      radial-gradient(circle at 70% 30%, rgba(109, 40, 217, 0.10), transparent 32%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.72), rgba(241, 245, 249, 0.78));
    box-shadow:
      0 28px 90px rgba(15, 23, 42, 0.10),
      inset 0 0 0 1px rgba(255, 255, 255, 0.34);
  }

  .sr-core-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
    background-size: 2.5rem 2.5rem;
    mask-image: radial-gradient(circle at 50% 50%, black 0%, transparent 74%);
    opacity: 0.55;
  }

  .sr-core-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.22), transparent 68%);
    filter: blur(12px);
    transform: translate(-50%, -50%);
    animation: sr-core-breathe 5.2s ease-in-out infinite;
  }

  .sr-signal-map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .sr-lines path {
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 8 14;
    opacity: 0.88;
  }

  .sr-lines-input path {
    stroke: url(#sr-signal-gradient);
    animation: sr-signal-dash 7s linear infinite;
  }

  .sr-lines-output path {
    stroke: url(#sr-output-gradient);
    animation: sr-signal-dash 6s linear infinite reverse;
  }

  .sr-packet-group circle {
    filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.72));
  }

  .sr-packet-input circle {
    fill: #22d3ee;
  }

  .sr-packet-output circle {
    fill: #22c55e;
  }

  .sr-core-unit {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 2;
    width: min(25rem, 62%);
    padding: 1.4rem;
    border: 1px solid rgba(148, 163, 184, 0.30);
    border-radius: 1.35rem;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(30, 41, 59, 0.74));
    box-shadow:
      0 24px 80px rgba(2, 6, 23, 0.40),
      0 0 44px rgba(34, 211, 238, 0.12),
      inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    transform: translate(-50%, -50%);
  }

  :global(:root[data-theme='light']) .sr-core-unit {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.84));
    box-shadow:
      0 24px 80px rgba(15, 23, 42, 0.14),
      0 0 44px rgba(14, 165, 233, 0.10),
      inset 0 0 0 1px rgba(255, 255, 255, 0.44);
  }

  .sr-core-unit-kicker,
  .sr-output-card span,
  .sr-signal-label {
    color: var(--sr-cyan);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sr-core-unit strong {
    display: block;
    margin-top: 0.45rem;
    color: var(--sr-text);
    font-size: clamp(1.35rem, 2.7vw, 2.1rem);
    line-height: 1.03;
    letter-spacing: -0.045em;
  }

  .sr-core-unit p {
    margin: 0.8rem 0 0;
    color: var(--sr-text-soft);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .sr-core-unit-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem;
    margin-top: 1rem;
  }

  .sr-core-unit-grid span,
  .sr-output-card {
    border: 1px solid rgba(148, 163, 184, 0.20);
    border-radius: 0.8rem;
    background: rgba(2, 6, 23, 0.30);
  }

  :global(:root[data-theme='light']) .sr-core-unit-grid span,
  :global(:root[data-theme='light']) .sr-output-card {
    background: rgba(255, 255, 255, 0.66);
  }

  .sr-core-unit-grid span {
    padding: 0.45rem 0.55rem;
    color: var(--sr-text-soft);
    font-size: 0.72rem;
    font-weight: 850;
  }

  .sr-signal-label {
    position: absolute;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.34rem 0.55rem;
    border: 1px solid rgba(34, 211, 238, 0.26);
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.62);
    box-shadow: 0 10px 34px rgba(2, 6, 23, 0.20);
    animation: sr-float 6s ease-in-out infinite;
  }

  :global(:root[data-theme='light']) .sr-signal-label {
    background: rgba(255, 255, 255, 0.72);
  }

  .sr-signal-label-a { left: 4%; top: 23%; animation-delay: -0.4s; }
  .sr-signal-label-b { left: 12%; bottom: 26%; animation-delay: -1.6s; }
  .sr-signal-label-c { left: 42%; top: 8%; animation-delay: -2.2s; }
  .sr-signal-label-d { right: 7%; top: 22%; animation-delay: -0.9s; }
  .sr-signal-label-e { right: 10%; bottom: 24%; animation-delay: -2.8s; }

  .sr-output-card {
    position: absolute;
    z-index: 4;
    max-width: 17rem;
    padding: 0.8rem 0.9rem;
    backdrop-filter: blur(16px);
  }

  .sr-output-card strong {
    display: block;
    margin-top: 0.3rem;
    color: var(--sr-text);
    font-size: 0.9rem;
    line-height: 1.35;
  }

  .sr-output-card-a { right: 5%; top: 15%; }
  .sr-output-card-b { right: 5%; bottom: 16%; }
  .sr-output-card-c { left: 6%; bottom: 9%; }

  @keyframes sr-signal-dash {
    to { stroke-dashoffset: -88; }
  }

  @keyframes sr-core-breathe {
    0%, 100% { opacity: 0.72; transform: translate(-50%, -50%) scale(0.94); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
  }

  @keyframes sr-float {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -8px, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sr-lines-input path,
    .sr-lines-output path,
    .sr-core-glow,
    .sr-signal-label {
      animation: none;
    }
  }

  @media (max-width: 1180px) {
    .sr-hero-core {
      min-height: auto;
    }

    .sr-core-visual {
      min-height: 32rem;
    }
  }

  @media (max-width: 760px) {
    .sr-hero-core {
      padding: 1.25rem;
    }

    .sr-core-visual {
      min-height: 34rem;
      border-radius: 1.4rem;
    }

    .sr-core-unit {
      width: 82%;
      padding: 1rem;
    }

    .sr-output-card {
      position: relative;
      left: auto;
      right: auto;
      top: auto;
      bottom: auto;
      display: block;
      max-width: none;
      margin: 0.55rem 0.8rem;
    }

    .sr-output-card-a {
      margin-top: 22rem;
    }

    .sr-signal-label-d,
    .sr-signal-label-e {
      display: none;
    }
  }


  /* Full-width landing composition. */
