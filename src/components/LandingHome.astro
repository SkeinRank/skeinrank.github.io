---
import { Image } from 'astro:assets';
import controlPlaneOverview from '../assets/diagrams/control-plane-overview.jpeg';

const repoUrl = 'https://github.com/SkeinRank/skeinrank';
const dockerQuickstartUrl = '/getting-started/docker-beta-quickstart/';
---

<section class="sr-landing" aria-labelledby="sr-home-title">
  <div class="sr-shell">
    <section class="sr-hero-block sr-hero-core sr-world-hero" aria-label="SkeinRank product hero">
      <div class="sr-hero-copy sr-hero-copy-core sr-world-copy">
        <div class="sr-kicker">
          <span class="sr-pulse" aria-hidden="true"></span>
          Open-source domain language control plane for search, RAG, and agents
        </div>

        <h1 id="sr-home-title">Turn messy aliases into governed search context.</h1>

        <p class="sr-subtitle">
          SkeinRank sits beside existing search, RAG, and agent systems. It turns aliases, acronyms,
          and internal jargon into explicit runtime context through profiles, bindings, snapshots, and evidence.
        </p>

        <div class="sr-actions" aria-label="Primary actions">
          <a class="sr-btn sr-btn-primary" href={dockerQuickstartUrl}>Docker beta</a>
          <a class="sr-btn sr-btn-secondary" href="/concepts/architecture/">Architecture</a>
          <a class="sr-btn sr-btn-ghost" href={repoUrl}>GitHub</a>
        </div>
      </div>

      <div class="sr-world-visual" aria-label="Terminology pipeline from aliases to runtime search context">
        <div class="sr-world-orbit sr-world-orbit-a" aria-hidden="true"></div>
        <div class="sr-world-orbit sr-world-orbit-b" aria-hidden="true"></div>

        <svg class="sr-world-flow" viewBox="0 0 980 560" aria-hidden="true">
          <defs>
            <linearGradient id="sr-world-line-a" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.05" />
              <stop offset="50%" stop-color="#22d3ee" stop-opacity="0.9" />
              <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.16" />
            </linearGradient>
            <linearGradient id="sr-world-line-b" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.18" />
              <stop offset="52%" stop-color="#22c55e" stop-opacity="0.92" />
              <stop offset="100%" stop-color="#22c55e" stop-opacity="0.05" />
            </linearGradient>
          </defs>

          <g class="sr-world-lines sr-world-lines-in">
            <path d="M170 172 C276 152 328 202 420 244" />
            <path d="M166 282 C282 284 334 272 420 282" />
            <path d="M170 396 C274 410 330 354 420 322" />
          </g>
          <g class="sr-world-lines sr-world-lines-out">
            <path d="M560 244 C650 196 716 174 826 174" />
            <path d="M560 282 C660 286 724 286 826 286" />
            <path d="M560 322 C650 370 716 394 826 394" />
          </g>
          <g class="sr-world-traces sr-world-traces-in">
            <path d="M170 172 C276 152 328 202 420 244" />
            <path d="M166 282 C282 284 334 272 420 282" />
            <path d="M170 396 C274 410 330 354 420 322" />
          </g>
          <g class="sr-world-traces sr-world-traces-out">
            <path d="M560 244 C650 196 716 174 826 174" />
            <path d="M560 282 C660 286 724 286 826 286" />
            <path d="M560 322 C650 370 716 394 826 394" />
          </g>

          <g class="sr-world-packets sr-world-packets-in">
            <circle cx="420" cy="244" r="4" />
            <circle cx="420" cy="282" r="3.5" />
            <circle cx="420" cy="322" r="4" />
          </g>
          <g class="sr-world-packets sr-world-packets-out">
            <circle cx="560" cy="244" r="4" />
            <circle cx="560" cy="282" r="3.5" />
            <circle cx="560" cy="322" r="4" />
          </g>
        </svg>

        <div class="sr-world-card sr-world-card-input">
          <div class="sr-world-card-head">
            <span>Input aliases</span>
            <strong>Noisy company language</strong>
          </div>
          <div class="sr-token-cloud" aria-hidden="true">
            <span>k8s</span>
            <span>kube</span>
            <span>pg</span>
            <span>postgres</span>
            <span>sev1</span>
            <span>docs_uni</span>
          </div>
        </div>

        <div class="sr-world-card sr-world-card-core">
          <div class="sr-world-card-head">
            <span>SkeinRank</span>
            <strong>Terminology control plane</strong>
          </div>
          <div class="sr-control-grid" aria-hidden="true">
            <span>profiles</span>
            <span>bindings</span>
            <span>guardrails</span>
            <span>evidence</span>
          </div>
          <div class="sr-runtime-strip">
            <span>snapshot</span>
            <strong>infra_incidents / S42</strong>
          </div>
        </div>

        <div class="sr-world-card sr-world-card-output">
          <div class="sr-world-card-head">
            <span>Runtime output</span>
            <strong>Search-ready context</strong>
          </div>
          <div class="sr-output-stack" aria-hidden="true">
            <div>
              <span>canonical query</span>
              <strong>kubernetes · postgresql · timeout</strong>
            </div>
            <div>
              <span>runtime context</span>
              <strong>binding_id + pinned snapshot</strong>
            </div>
            <div>
              <span>side-car API</span>
              <strong>Elasticsearch / RAG / agents</strong>
            </div>
          </div>
        </div>

      </div>
    </section>

    <section class="sr-section sr-console-preview sr-overview-preview" aria-labelledby="sr-console-preview-title">
      <div class="sr-preview-heading">
        <p class="sr-section-label">System overview</p>
        <h2 id="sr-console-preview-title">From domain language to runtime context.</h2>
        <p>
          Start with the runtime model: profiles define language, bindings select the search
          context, and snapshots pin the version that search, RAG, and agents can safely use.
        </p>
      </div>

      <div class="sr-diagram-showcase" aria-label="SkeinRank control plane architecture overview">
        <figure class="sr-diagram-hero-card">
          <Image
            class="sr-diagram-image"
            src={controlPlaneOverview}
            alt="SkeinRank control plane architecture showing applications, runtime capabilities, execution targets, and support services."
            width={1672}
            format="webp"
            quality={86}
            loading="lazy"
          />
          <figcaption>
            Control-plane overview: applications call SkeinRank before search, RAG, and runtime APIs consume governed context.
          </figcaption>
        </figure>

        <div class="sr-diagram-proof-grid" aria-label="Product architecture proof points">
          <article>
            <span>Runtime context</span>
            <strong>binding-aware request flow</strong>
            <p>Queries can be canonicalized and routed with an explicit binding, pinned snapshot, and policy-aware context.</p>
          </article>
          <article>
            <span>Governed model</span>
            <strong>profiles · aliases · evidence</strong>
            <p>Domain language becomes reviewable platform state instead of hidden synonym files or prompt-only heuristics.</p>
          </article>
          <article>
            <span>Integration layer</span>
            <strong>MCP · APIs · GitOps</strong>
            <p>Agents, search services, and CI workflows can consume the same terminology package and runtime model.</p>
          </article>
          <a class="sr-inline-architecture-link" href="/concepts/architecture/">Open architecture docs</a>
        </div>
      </div>
    </section>

    <section class="sr-problem-solution" aria-labelledby="sr-problem-title">
      <div>
        <p class="sr-section-label">The problem</p>
        <h2 id="sr-problem-title">Enterprise search loses context when terminology is unmanaged.</h2>
      </div>
      <div class="sr-split-panels">
        <article class="sr-panel sr-before">
          <span class="sr-panel-label">Without SkeinRank</span>
          <p>
            Search and RAG pipelines depend on raw text. <code>k8s</code>, <code>kube</code>, <code>postgres</code>,
            <code>pg</code>, team names, and internal aliases compete without a governed runtime model.
          </p>
        </article>
        <article class="sr-panel sr-after">
          <span class="sr-panel-label">With SkeinRank</span>
          <p>
            Terminology changes are reviewed, bound to specific search contexts, rolled out through enrichment,
            and served from immutable snapshots that explain what runtime search is using.
          </p>
        </article>
      </div>
    </section>

    <section class="sr-section" aria-labelledby="sr-how-title">
      <div class="sr-section-heading">
        <p class="sr-section-label">Console workflow</p>
        <h2 id="sr-how-title">From terminology governance to verified search behavior.</h2>
        <p>
          The governance console is designed as an operator workflow: run the Docker beta stack, define terminology, apply it to an index,
          run enrichment, audit the active snapshot, and test the runtime query path before integrating it downstream.
        </p>
      </div>

      <div class="sr-pipeline-v2">
        <article>
          <span>01</span>
          <h3>Profile</h3>
          <p>Create a terminology profile with canonical terms, aliases, slots, suggestions, and guardrails.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Binding</h3>
          <p>Attach one profile to one Elasticsearch index, alias, or scoped document collection.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Enrichment</h3>
          <p>Run dry-runs and jobs that write canonical attributes or prepare rollout metadata.</p>
        </article>
        <article>
          <span>04</span>
          <h3>Snapshot</h3>
          <p>Audit the immutable runtime version currently pinned to each binding.</p>
        </article>
        <article>
          <span>05</span>
          <h3>Search Playground</h3>
          <p>Verify canonical queries, matched aliases, snapshots, and search hits from the UI.</p>
        </article>
      </div>
    </section>

    <section class="sr-section" aria-labelledby="sr-layers-title">
      <div class="sr-section-heading sr-narrow">
        <p class="sr-section-label">Product shape</p>
        <h2 id="sr-layers-title">A side-car for terminology-aware search, not a replacement for your search stack.</h2>
      </div>

      <div class="sr-feature-grid">
        <article class="sr-feature-card sr-feature-primary">
          <div class="sr-icon">◎</div>
          <h3>Runtime search context</h3>
          <p>Use bindings to decide which terminology profile, index, fields, filters, and snapshot belong to a query.</p>
          <span class="sr-status sr-preview">Console beta</span>
        </article>
        <article class="sr-feature-card">
          <div class="sr-icon">↔</div>
          <h3>Canonicalize terminology</h3>
          <p>Normalize aliases and jargon into stable technical values controlled by profiles and guardrails.</p>
          <span class="sr-status sr-ready">Available</span>
        </article>
        <article class="sr-feature-card">
          <div class="sr-icon">⌘</div>
          <h3>Run locally with SDK/CLI</h3>
          <p>Validate dictionaries, extract attributes, and canonicalize text or documents without deploying services.</p>
          <span class="sr-status sr-ready">Available</span>
        </article>
        <article class="sr-feature-card">
          <div class="sr-icon">◈</div>
          <h3>Govern changes</h3>
          <p>Review suggestions, enforce stop-lists, manage users/tokens, and keep terminology changes auditable.</p>
          <span class="sr-status sr-preview">Console beta</span>
        </article>
        <article class="sr-feature-card">
          <div class="sr-icon">⇡</div>
          <h3>Enrich search indexes</h3>
          <p>Run dry-runs and enrichment jobs against Elasticsearch bindings with job history and rollback metadata.</p>
          <span class="sr-status sr-preview">Preview</span>
        </article>
        <article class="sr-feature-card">
          <div class="sr-icon">▣</div>
          <h3>Audit runtime snapshots</h3>
          <p>See which immutable version is active for each binding and why a search context is ready or stale.</p>
          <span class="sr-status sr-preview">Console beta</span>
        </article>
      </div>
    </section>

    <section class="sr-section sr-dashboard-section" aria-labelledby="sr-dashboard-title">
      <div class="sr-dashboard-copy">
        <p class="sr-section-label">Side-car model</p>
        <h2 id="sr-dashboard-title">SkeinRank sits beside Elasticsearch, RAG, and internal search UIs.</h2>
        <p>
          It does not need to replace the existing search engine. It manages domain terminology, produces
          canonicalized signals, and exposes runtime APIs that your application can call by binding or search scope.
        </p>
        <a class="sr-inline-link" href="/concepts/sidecar-model/">Read the side-car model →</a>
        <a class="sr-inline-link" href="/getting-started/docker-beta-quickstart/">Run the Docker beta stack →</a>
      </div>

      <div class="sr-dashboard-card" aria-label="SkeinRank side-car flow">
        <div class="sr-dashboard-head">
          <span>Existing stack</span>
          <strong>Search UI / backend / RAG service</strong>
        </div>
        <div class="sr-dashboard-row">
          <span>calls</span>
          <strong>SkeinRank runtime API</strong>
          <em>binding_id</em>
        </div>
        <div class="sr-dashboard-row">
          <span>uses</span>
          <strong>runtime snapshot</strong>
          <em>pinned</em>
        </div>
        <div class="sr-dashboard-row">
          <span>searches</span>
          <strong>Elasticsearch / document index</strong>
          <em>existing data</em>
        </div>
        <div class="sr-dashboard-footer">
          <span>Profiles define terminology</span>
          <span>Bindings define runtime context</span>
        </div>
      </div>
    </section>

    <section class="sr-section sr-status-section" aria-labelledby="sr-status-title">
      <div class="sr-section-heading sr-narrow">
        <p class="sr-section-label">Current status</p>
        <h2 id="sr-status-title">Public positioning: usable core, beta governance platform.</h2>
        <p>
          The site presents SkeinRank honestly: the core SDK/CLI path is the smallest stable entry point,
          while the governance console and Elasticsearch workflows are documented as beta/platform preview.
        </p>
      </div>

      <div class="sr-status-table" role="table" aria-label="SkeinRank component status">
        <div role="row" class="sr-status-row sr-status-row-head">
          <span role="columnheader">Area</span>
          <span role="columnheader">Status</span>
          <span role="columnheader">Meaning</span>
        </div>
        <div role="row" class="sr-status-row">
          <span role="cell">Core SDK / CLI</span>
          <span role="cell"><mark class="sr-status sr-ready">Available</mark></span>
          <span role="cell">Local validation, extraction, canonicalization, and explainable passport output.</span>
        </div>
        <div role="row" class="sr-status-row">
          <span role="cell">Governance console</span>
          <span role="cell"><mark class="sr-status sr-preview">Beta</mark></span>
          <span role="cell">Dashboard, Terms, Suggestions, Guardrails, Integrations, Snapshots, Search Playground, API Access, and Users.</span>
        </div>
        <div role="row" class="sr-status-row">
          <span role="cell">Elasticsearch enrichment</span>
          <span role="cell"><mark class="sr-status sr-preview">Preview</mark></span>
          <span role="cell">Bindings, dry-runs, enrichment jobs, graph view, rollout metadata, and snapshot audit.</span>
        </div>
        <div role="row" class="sr-status-row">
          <span role="cell">Docker beta stack</span>
          <span role="cell"><mark class="sr-status sr-preview">Beta docs</mark></span>
          <span role="cell">Local Docker Compose quickstart for the governance UI, API, PostgreSQL, Elasticsearch, RabbitMQ worker, and optional observability profile.</span>
        </div>
      </div>
    </section>

    <section class="sr-cta" aria-labelledby="sr-cta-title">
      <div>
        <p class="sr-section-label">Try the beta stack</p>
        <h2 id="sr-cta-title">Run the console locally, then follow the workflow.</h2>
        <p>Start with Docker Compose for the platform beta, or read the runtime model before connecting real search indexes.</p>
      </div>
      <div class="sr-cta-actions">
        <a class="sr-btn sr-btn-primary" href="/getting-started/docker-beta-quickstart/">Run Docker beta</a>
        <a class="sr-btn sr-btn-secondary" href="/concepts/profiles-bindings-snapshots/">Read runtime model</a>
      </div>
    </section>
  </div>
</section>

<style>
  .sr-landing {
    --sr-bg: #020617;
    --sr-surface: rgba(15, 23, 42, 0.78);
    --sr-surface-strong: rgba(15, 23, 42, 0.94);
    --sr-card: rgba(15, 23, 42, 0.72);
    --sr-card-soft: rgba(30, 41, 59, 0.58);
    --sr-border: rgba(148, 163, 184, 0.22);
    --sr-border-strong: rgba(148, 163, 184, 0.34);
    --sr-text: #f8fafc;
    --sr-text-soft: #cbd5e1;
    --sr-muted: #94a3b8;
    --sr-accent: #8b5cf6;
    --sr-accent-strong: #a78bfa;
    --sr-cyan: #22d3ee;
    --sr-green: #22c55e;
    --sr-amber: #f59e0b;
    --sr-shadow: 0 28px 90px rgba(2, 6, 23, 0.42);
    --sr-radius-lg: 2rem;
    --sr-radius-md: 1.25rem;

    color: var(--sr-text);
    margin: -0.25rem 0 0;
  }

  :global(:root[data-theme='light']) .sr-landing {
    --sr-bg: #f8fafc;
    --sr-surface: rgba(255, 255, 255, 0.88);
    --sr-surface-strong: rgba(255, 255, 255, 0.98);
    --sr-card: rgba(255, 255, 255, 0.82);
    --sr-card-soft: rgba(241, 245, 249, 0.84);
    --sr-border: rgba(100, 116, 139, 0.22);
    --sr-border-strong: rgba(100, 116, 139, 0.32);
    --sr-text: #0f172a;
    --sr-text-soft: #334155;
    --sr-muted: #64748b;
    --sr-accent: #6d28d9;
    --sr-accent-strong: #7c3aed;
    --sr-cyan: #0891b2;
    --sr-green: #15803d;
    --sr-amber: #b45309;
    --sr-shadow: 0 24px 80px rgba(15, 23, 42, 0.12);
  }

  .sr-shell {
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
  }
  .sr-problem-solution,
  .sr-section,
  .sr-cta {
    content-visibility: auto;
    contain-intrinsic-size: 1px 780px;
  }


  .sr-hero-block {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    border: 1px solid var(--sr-border);
    border-radius: var(--sr-radius-lg);
    background:
      radial-gradient(circle at 12% 12%, rgba(34, 211, 238, 0.18), transparent 32%),
      radial-gradient(circle at 88% 18%, rgba(139, 92, 246, 0.22), transparent 34%),
      linear-gradient(135deg, var(--sr-surface-strong), var(--sr-surface));
    box-shadow: var(--sr-shadow);
  }

  .sr-hero-block::before {
    content: '';
    position: absolute;
    inset: auto -10% -30% 30%;
    z-index: -1;
    height: 18rem;
    background: linear-gradient(90deg, rgba(34, 211, 238, 0.12), rgba(139, 92, 246, 0.14));
    opacity: 0.7;
    transform: rotate(-6deg);
  }

  .sr-kicker,
  .sr-section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    margin: 0 0 1rem;
    padding: 0.42rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--sr-cyan) 35%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--sr-cyan) 10%, transparent);
    color: var(--sr-cyan);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.03em;
  }

  .sr-pulse {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--sr-green);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--sr-green) 14%, transparent);
  }

  .sr-hero-copy h1 {
    max-width: 11ch;
    margin: 0;
    color: var(--sr-text);
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
  }

  .sr-subtitle {
    max-width: 46rem;
    margin: 1.35rem 0 0;
    color: var(--sr-text-soft);
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    line-height: 1.75;
  }

  .sr-actions,
  .sr-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.6rem;
  }

  .sr-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.85rem;
    padding: 0.78rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--sr-border-strong);
    font-weight: 800;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .sr-btn:hover {
    transform: translateY(-1px);
    text-decoration: none;
  }

  .sr-btn-primary {
    color: white;
    border-color: color-mix(in srgb, var(--sr-accent) 70%, transparent);
    background: linear-gradient(135deg, var(--sr-accent), color-mix(in srgb, var(--sr-cyan) 70%, var(--sr-accent)));
    box-shadow: 0 18px 36px color-mix(in srgb, var(--sr-accent) 24%, transparent);
  }

  .sr-btn-secondary,
  .sr-btn-ghost {
    color: var(--sr-text);
    background: color-mix(in srgb, var(--sr-surface-strong) 86%, transparent);
  }

  .sr-btn-ghost {
    border-color: color-mix(in srgb, var(--sr-cyan) 24%, transparent);
    color: var(--sr-cyan);
    background: color-mix(in srgb, var(--sr-cyan) 7%, transparent);
  }

  .sr-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 2rem 0 0;
  }

  .sr-metrics div {
    padding: 0.9rem;
    border: 1px solid var(--sr-border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sr-card-soft) 75%, transparent);
  }

  .sr-metrics dt {
    margin: 0;
    color: var(--sr-muted);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-metrics dd {
    margin: 0.35rem 0 0;
    color: var(--sr-text);
    font-weight: 900;
  }

  .sr-hero-visual {
    position: relative;
    min-height: 33rem;
  }

  .sr-terminal-card,
  .sr-dashboard-card,
  .sr-panel,
  .sr-feature-card,
  .sr-status-table,
  .sr-cta {
    border: 1px solid var(--sr-border);
    border-radius: var(--sr-radius-md);
    background: linear-gradient(145deg, var(--sr-surface-strong), var(--sr-card));
    box-shadow: var(--sr-shadow);
  }

  .sr-terminal-card {
    position: relative;
    z-index: 1;
    overflow: hidden;
    transform: rotate(1.2deg);
  }

  .sr-window-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--sr-border);
    background: color-mix(in srgb, var(--sr-card-soft) 82%, transparent);
  }

  .sr-dot {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sr-muted) 55%, transparent);
  }

  .sr-window-title {
    margin-left: auto;
    color: var(--sr-muted);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .sr-terminal-body {
    padding: clamp(1.1rem, 3vw, 1.6rem);
  }

  .sr-terminal-body p {
    margin: 1rem 0 0.4rem;
  }

  .sr-terminal-body p:first-child {
    margin-top: 0;
  }

  .sr-command-line,
  .sr-trace-code {
    display: block;
    margin: 0;
    padding: 0.9rem;
    overflow-x: auto;
    border: 1px solid var(--sr-border);
    border-radius: 0.95rem;
    background: color-mix(in srgb, #020617 86%, var(--sr-card));
    color: #e0f2fe;
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .sr-command-line {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 1rem;
    color: #67e8f9;
  }

  .sr-command-line code {
    border: 0 !important;
    padding: 0 !important;
    color: #e0f2fe !important;
    background: transparent !important;
    font: inherit;
  }

  .sr-trace-code code {
    border: 0 !important;
    padding: 0 !important;
    color: inherit;
    background: transparent !important;
    font: inherit;
  }

  .sr-demo-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 0.8rem;
    margin: 0 0 1rem;
  }

  .sr-demo-pane {
    min-height: 6.4rem;
    padding: 0.9rem;
    border: 1px solid var(--sr-border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sr-card-soft) 72%, transparent);
  }

  .sr-demo-pane strong {
    display: block;
    margin-top: 0.55rem;
    color: var(--sr-text);
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  :global(:root[data-theme='light']) .sr-command-line,
  :global(:root[data-theme='light']) .sr-trace-code {
    background: #0f172a;
    color: #e0f2fe;
  }

  .sr-code-key { color: #93c5fd; }
  .sr-code-str { color: #86efac; }
  .sr-code-bool { color: #f0abfc; }
  .sr-code-punct { color: #cbd5e1; }

  .sr-muted {
    color: var(--sr-muted);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-token-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .sr-token {
    display: inline-flex;
    padding: 0.42rem 0.62rem;
    border: 1px solid color-mix(in srgb, var(--sr-cyan) 35%, transparent);
    border-radius: 999px;
    color: var(--sr-cyan);
    background: color-mix(in srgb, var(--sr-cyan) 10%, transparent);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .sr-floating-card {
    position: absolute;
    z-index: 2;
    width: max-content;
    max-width: 15rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid var(--sr-border-strong);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sr-surface-strong) 86%, transparent);
    box-shadow: var(--sr-shadow);
    backdrop-filter: blur(18px);
  }

  .sr-floating-card span {
    display: block;
    color: var(--sr-muted);
    font-size: 0.72rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-floating-card strong {
    display: block;
    margin-top: 0.25rem;
    color: var(--sr-text);
  }

  .sr-card-a {
    left: -1rem;
    bottom: 4.5rem;
  }

  .sr-card-b {
    right: -0.4rem;
    top: 3rem;
  }

  .sr-section,
  .sr-problem-solution,
  .sr-dashboard-section,
  .sr-status-section {
    display: grid;
    gap: 1.5rem;
  }

  .sr-problem-solution,
  .sr-dashboard-section,
  .sr-cta {
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    align-items: center;
  }

  .sr-section-heading {
    max-width: 56rem;
  }

  .sr-section-heading.sr-narrow {
    max-width: 48rem;
  }

  .sr-section h2,
  .sr-problem-solution h2,
  .sr-dashboard-section h2,
  .sr-cta h2 {
    margin: 0;
    color: var(--sr-text);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .sr-section-heading p:not(.sr-section-label),
  .sr-dashboard-copy p:not(.sr-section-label),
  .sr-cta p {
    max-width: 48rem;
    margin: 0.9rem 0 0;
    color: var(--sr-text-soft);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .sr-split-panels {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .sr-panel {
    min-height: 13rem;
    padding: 1.25rem;
  }

  .sr-panel-label {
    display: inline-flex;
    margin-bottom: 0.9rem;
    padding: 0.32rem 0.55rem;
    border-radius: 999px;
    color: var(--sr-muted);
    background: var(--sr-card-soft);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-panel p,
  .sr-feature-card p {
    margin: 0;
    color: var(--sr-text-soft);
    line-height: 1.7;
  }

  .sr-panel code {
    color: var(--sr-cyan);
  }

  .sr-pipeline-v2 {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .sr-pipeline-v2 article,
  .sr-feature-card {
    position: relative;
    overflow: hidden;
    padding: 1.1rem;
    border: 1px solid var(--sr-border);
    border-radius: 1.2rem;
    background: linear-gradient(145deg, var(--sr-card), color-mix(in srgb, var(--sr-card-soft) 70%, transparent));
  }

  .sr-pipeline-v2 article::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 22% 0%, color-mix(in srgb, var(--sr-accent) 13%, transparent), transparent 38%);
  }

  .sr-pipeline-v2 span {
    color: var(--sr-cyan);
    font-size: 0.78rem;
    font-weight: 950;
  }

  .sr-pipeline-v2 h3,
  .sr-feature-card h3 {
    position: relative;
    z-index: 1;
    margin: 0.55rem 0 0.4rem;
    color: var(--sr-text);
    font-size: 1rem;
  }

  .sr-pipeline-v2 p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--sr-muted);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .sr-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .sr-feature-primary {
    grid-row: span 2;
    padding: 1.35rem;
    background:
      radial-gradient(circle at 20% 10%, color-mix(in srgb, var(--sr-cyan) 20%, transparent), transparent 38%),
      linear-gradient(145deg, var(--sr-surface-strong), var(--sr-card));
  }

  .sr-icon {
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid color-mix(in srgb, var(--sr-accent) 35%, transparent);
    border-radius: 0.85rem;
    color: var(--sr-accent-strong);
    background: color-mix(in srgb, var(--sr-accent) 10%, transparent);
    font-weight: 950;
  }

  .sr-status {
    display: inline-flex;
    width: fit-content;
    margin-top: 1rem;
    padding: 0.3rem 0.58rem;
    border-radius: 999px;
    border: 1px solid var(--sr-border);
    font-size: 0.74rem;
    font-weight: 900;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.055em;
  }

  .sr-ready {
    color: var(--sr-green);
    border-color: color-mix(in srgb, var(--sr-green) 32%, transparent);
    background: color-mix(in srgb, var(--sr-green) 10%, transparent);
  }

  .sr-preview {
    color: var(--sr-amber);
    border-color: color-mix(in srgb, var(--sr-amber) 34%, transparent);
    background: color-mix(in srgb, var(--sr-amber) 10%, transparent);
  }

  .sr-planned {
    color: var(--sr-muted);
    background: var(--sr-card-soft);
  }

  .sr-dashboard-section {
    padding: clamp(1.5rem, 4vw, 2.2rem);
    border: 1px solid var(--sr-border);
    border-radius: var(--sr-radius-lg);
    background:
      radial-gradient(circle at 10% 20%, color-mix(in srgb, var(--sr-accent) 16%, transparent), transparent 30%),
      linear-gradient(135deg, var(--sr-surface), color-mix(in srgb, var(--sr-card-soft) 70%, transparent));
  }

  .sr-inline-link {
    display: inline-flex;
    margin-top: 1.1rem;
    color: var(--sr-cyan);
    font-weight: 900;
    text-decoration: none;
  }

  .sr-inline-link:hover {
    text-decoration: underline;
  }

  .sr-dashboard-card {
    overflow: hidden;
    padding: 0.95rem;
  }

  .sr-console-preview {
    position: relative;
    gap: 1.35rem;
    padding: clamp(1.15rem, 3vw, 1.65rem);
    overflow: hidden;
    border: 1px solid var(--sr-border);
    border-radius: var(--sr-radius-lg);
    background:
      radial-gradient(circle at 14% 0%, color-mix(in srgb, var(--sr-cyan) 16%, transparent), transparent 22rem),
      radial-gradient(circle at 86% 2%, color-mix(in srgb, var(--sr-accent) 18%, transparent), transparent 24rem),
      linear-gradient(145deg, color-mix(in srgb, var(--sr-card-soft) 70%, transparent), color-mix(in srgb, var(--sr-surface-strong) 86%, transparent));
    box-shadow: var(--sr-shadow);
  }

  .sr-preview-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(17rem, 0.55fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: end;
  }

  .sr-preview-heading .sr-section-label {
    grid-column: 1 / -1;
    margin-bottom: -0.1rem;
  }

  .sr-preview-heading h2 {
    max-width: 13ch;
  }

  .sr-preview-heading p:not(.sr-section-label) {
    margin: 0;
    color: var(--sr-text-soft);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .sr-preview-stage {
    display: grid;
    gap: 1rem;
  }

  .sr-preview-mobile-proof {
    display: none;
  }

  .sr-preview-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sr-border-strong) 84%, transparent);
    border-radius: 1.45rem;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(2, 6, 23, 0.92));
    box-shadow:
      0 28px 90px rgba(2, 6, 23, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .sr-preview-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 14%),
      radial-gradient(circle at 88% 4%, rgba(139, 92, 246, 0.14), transparent 18rem);
  }

  .sr-preview-toolbar {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.42rem;
    min-height: 2.35rem;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(2, 6, 23, 0.72);
  }

  .sr-preview-toolbar span {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.45);
  }

  .sr-preview-toolbar span:first-child {
    background: #ef4444;
  }

  .sr-preview-toolbar span:nth-child(2) {
    background: #f59e0b;
  }

  .sr-preview-toolbar span:nth-child(3) {
    background: #22c55e;
  }

  .sr-preview-toolbar strong {
    margin-inline-start: 0.45rem;
    color: rgba(226, 232, 240, 0.8);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.02em;
  }

  .sr-preview-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top left;
  }

  .sr-preview-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .sr-preview-proof-grid article {
    padding: 1rem;
    border: 1px solid var(--sr-border);
    border-radius: 1.1rem;
    background: color-mix(in srgb, var(--sr-card) 78%, transparent);
  }

  .sr-preview-proof-grid span {
    display: inline-flex;
    margin-bottom: 0.55rem;
    color: var(--sr-cyan);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sr-preview-proof-grid strong {
    display: block;
    color: var(--sr-text);
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .sr-preview-proof-grid p {
    margin: 0.5rem 0 0;
    color: var(--sr-text-soft);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .sr-preview-proof-grid code {
    color: var(--sr-cyan);
  }

  .sr-preview-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .sr-dashboard-head,
  .sr-dashboard-row,
  .sr-dashboard-footer {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr 0.8fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem;
    border-bottom: 1px solid var(--sr-border);
  }

  .sr-dashboard-head {
    grid-template-columns: 1fr;
    border-radius: 0.95rem;
    background: var(--sr-card-soft);
  }

  .sr-dashboard-head span,
  .sr-dashboard-row span {
    color: var(--sr-muted);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .sr-dashboard-head strong,
  .sr-dashboard-row strong {
    color: var(--sr-text);
  }

  .sr-dashboard-row em {
    justify-self: end;
    color: var(--sr-cyan);
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 850;
  }

  .sr-dashboard-footer {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-bottom: 0;
    color: var(--sr-muted);
    font-size: 0.78rem;
  }

  .sr-status-table {
    overflow: hidden;
  }

  .sr-status-row {
    display: grid;
    grid-template-columns: 0.8fr 0.55fr 1.65fr;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--sr-border);
  }

  .sr-status-row:last-child {
    border-bottom: 0;
  }

  .sr-status-row span {
    color: var(--sr-text-soft);
  }

  .sr-status-row span:first-child {
    color: var(--sr-text);
    font-weight: 850;
  }

  .sr-status-row-head {
    background: var(--sr-card-soft);
  }

  .sr-status-row-head span {
    color: var(--sr-muted) !important;
    font-size: 0.76rem;
    font-weight: 950;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-status-row mark {
    margin: 0;
  }

  .sr-cta {
    padding: clamp(1.5rem, 4vw, 2rem);
  }

  @media (max-width: 1180px) {
    .sr-hero-block,
    .sr-problem-solution,
    .sr-dashboard-section,
    .sr-cta {
      grid-template-columns: 1fr;
    }

    .sr-hero-copy h1 {
      max-width: 13ch;
    }

    .sr-hero-visual {
      min-height: auto;
    }

    .sr-terminal-card {
      transform: none;
    }

    .sr-floating-card {
      position: static;
      display: inline-block;
      margin: 0.8rem 0.5rem 0 0;
    }

    .sr-pipeline-v2,
    .sr-feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }


    .sr-preview-heading {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .sr-preview-heading h2 {
      max-width: 17ch;
    }

    .sr-preview-proof-grid {
      grid-template-columns: 1fr;
    }

    .sr-feature-primary {
      grid-row: auto;
    }
  }

  @media (max-width: 760px) {
    .sr-hero-block {
      padding: 1.25rem;
      border-radius: 1.5rem;
    }

    .sr-metrics,
    .sr-demo-grid,
    .sr-split-panels,
    .sr-pipeline-v2,
    .sr-feature-grid,
    .sr-dashboard-footer {
      grid-template-columns: 1fr;
    }

    .sr-status-row,
    .sr-dashboard-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      align-items: start;
    }

    .sr-dashboard-row em {
      justify-self: start;
    }
  }
  /* Site Patch 8A: cinematic terminology control core hero. */
  .sr-hero-core {
    grid-template-columns: minmax(21rem, 0.84fr) minmax(34rem, 1.16fr);
    min-height: min(72vh, 48rem);
    padding: clamp(2rem, 5vw, 4.6rem);
    background:
      radial-gradient(circle at 18% 20%, rgba(34, 211, 238, 0.17), transparent 29%),
      radial-gradient(circle at 78% 16%, rgba(139, 92, 246, 0.25), transparent 34%),
      radial-gradient(circle at 56% 82%, rgba(34, 197, 94, 0.10), transparent 32%),
      linear-gradient(135deg, rgba(2, 6, 23, 0.98), rgba(15, 23, 42, 0.86));
  }

  .sr-hero-core::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px);
    background-size: 3.2rem 3.2rem;
    mask-image: radial-gradient(circle at 64% 48%, black 0%, transparent 62%);
    opacity: 0.42;
  }

  :global(:root[data-theme='light']) .sr-hero-core {
    background:
      radial-gradient(circle at 18% 20%, rgba(14, 165, 233, 0.18), transparent 30%),
      radial-gradient(circle at 78% 16%, rgba(109, 40, 217, 0.18), transparent 34%),
      radial-gradient(circle at 56% 82%, rgba(22, 163, 74, 0.10), transparent 32%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 249, 0.92));
  }

  .sr-hero-copy-core h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 6.4vw, 6rem);
  }

  .sr-core-metrics div {
    backdrop-filter: blur(18px);
  }

  .sr-core-visual {
    position: relative;
    min-height: clamp(33rem, 42vw, 42rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sr-border) 92%, transparent);
    border-radius: 2rem;
    background:
      radial-gradient(circle at 50% 50%, rgba(34, 211, 238, 0.13), transparent 24%),
      radial-gradient(circle at 70% 30%, rgba(139, 92, 246, 0.16), transparent 32%),
      linear-gradient(145deg, rgba(2, 6, 23, 0.42), rgba(15, 23, 42, 0.58));
    box-shadow:
      0 28px 90px rgba(2, 6, 23, 0.26),
      inset 0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  :global(:root[data-theme='light']) .sr-core-visual {
    background:
      radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.12), transparent 24%),
      radial-gradient(circle at 70% 30%, rgba(109, 40, 217, 0.10), transparent 32%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.72), rgba(241, 245, 249, 0.78));
    box-shadow:
      0 28px 90px rgba(15, 23, 42, 0.10),
      inset 0 0 0 1px rgba(255, 255, 255, 0.34);
  }

  .sr-core-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
    background-size: 2.5rem 2.5rem;
    mask-image: radial-gradient(circle at 50% 50%, black 0%, transparent 74%);
    opacity: 0.55;
  }

  .sr-core-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.22), transparent 68%);
    filter: blur(12px);
    transform: translate(-50%, -50%);
    animation: sr-core-breathe 5.2s ease-in-out infinite;
  }

  .sr-signal-map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .sr-lines path {
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 8 14;
    opacity: 0.88;
  }

  .sr-lines-input path {
    stroke: url(#sr-signal-gradient);
    animation: sr-signal-dash 7s linear infinite;
  }

  .sr-lines-output path {
    stroke: url(#sr-output-gradient);
    animation: sr-signal-dash 6s linear infinite reverse;
  }

  .sr-packet-group circle {
    filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.72));
  }

  .sr-packet-input circle {
    fill: #22d3ee;
  }

  .sr-packet-output circle {
    fill: #22c55e;
  }

  .sr-core-unit {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 2;
    width: min(25rem, 62%);
    padding: 1.4rem;
    border: 1px solid rgba(148, 163, 184, 0.30);
    border-radius: 1.35rem;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(30, 41, 59, 0.74));
    box-shadow:
      0 24px 80px rgba(2, 6, 23, 0.40),
      0 0 44px rgba(34, 211, 238, 0.12),
