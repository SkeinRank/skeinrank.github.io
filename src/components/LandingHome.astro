  .sr-terminal-body p {
    margin: 1rem 0 0.4rem;
  }

  .sr-terminal-body p:first-child {
    margin-top: 0;
  }

  .sr-command-line,
  .sr-trace-code {
    display: block;
    margin: 0;
    padding: 0.9rem;
    overflow-x: auto;
    border: 1px solid var(--sr-border);
    border-radius: 0.95rem;
    background: color-mix(in srgb, #020617 86%, var(--sr-card));
    color: #e0f2fe;
    font-size: 0.88rem;
    line-height: 1.65;
