  .sr-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 2rem 0 0;
  }

  .sr-metrics div {
    padding: 0.9rem;
    border: 1px solid var(--sr-border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sr-card-soft) 75%, transparent);
