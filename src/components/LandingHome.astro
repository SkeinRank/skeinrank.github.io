  :global(:root[data-theme='light']) .sr-command-line,
  :global(:root[data-theme='light']) .sr-trace-code {
    background: #0f172a;
    color: #e0f2fe;
  }

  .sr-code-key { color: #93c5fd; }
  .sr-code-str { color: #86efac; }
  .sr-code-bool { color: #f0abfc; }
  .sr-code-punct { color: #cbd5e1; }

  .sr-muted {
    color: var(--sr-muted);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-token-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .sr-token {
    display: inline-flex;
    padding: 0.42rem 0.62rem;
    border: 1px solid color-mix(in srgb, var(--sr-cyan) 35%, transparent);
    border-radius: 999px;
    color: var(--sr-cyan);
    background: color-mix(in srgb, var(--sr-cyan) 10%, transparent);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .sr-floating-card {
    position: absolute;
    z-index: 2;
    width: max-content;
    max-width: 15rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid var(--sr-border-strong);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sr-surface-strong) 86%, transparent);
    box-shadow: var(--sr-shadow);
    backdrop-filter: blur(18px);
  }

  .sr-floating-card span {
    display: block;
    color: var(--sr-muted);
    font-size: 0.72rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-floating-card strong {
    display: block;
    margin-top: 0.25rem;
    color: var(--sr-text);
  }

  .sr-card-a {
    left: -1rem;
    bottom: 4.5rem;
  }

  .sr-card-b {
    right: -0.4rem;
    top: 3rem;
  }

  .sr-section,
  .sr-dashboard-section,
  .sr-status-section {
    display: grid;
    gap: 1.5rem;
  }

  .sr-sdk-quickstart {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(460px, 1fr);
    align-items: center;
    gap: clamp(2rem, 4.5vw, 3.75rem);
    padding: clamp(1.85rem, 4.4vw, 3.25rem);
    border: 1px solid color-mix(in srgb, var(--sr-border-strong) 66%, transparent);
    border-radius: calc(var(--sr-radius-lg) + 0.2rem);
    background:
      radial-gradient(circle at 12% 14%, color-mix(in srgb, var(--sr-green) 10%, transparent), transparent 28%),
      radial-gradient(circle at 92% 2%, color-mix(in srgb, var(--sr-cyan) 12%, transparent), transparent 34%),
      linear-gradient(135deg, color-mix(in srgb, var(--sr-surface-strong) 95%, #020617), color-mix(in srgb, var(--sr-surface) 96%, #020617));
    box-shadow: 0 28px 80px rgba(2, 6, 23, 0.3);
  }

  .sr-sdk-copy {
    align-self: center;
  }

  .sr-sdk-copy h2 {
    max-width: 11ch;
    margin: 0;
    color: var(--sr-text);
    font-size: clamp(2.2rem, 4.8vw, 4.05rem);
    line-height: 1.035;
    letter-spacing: -0.028em;
  }

  .sr-sdk-copy p {
    max-width: 52ch;
    margin: 1rem 0 0;
    color: var(--sr-text-soft);
    font-size: clamp(1rem, 1.45vw, 1.1rem);
    line-height: 1.62;
  }

  .sr-sdk-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.95rem;
    margin-top: 1.3rem;
  }

  .sr-sdk-terminal {
    overflow: hidden;
    align-self: center;
    display: grid;
    gap: 0;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 1.45rem;
    background:
      radial-gradient(circle at 72% 0%, rgba(34, 211, 238, 0.07), transparent 30%),
      linear-gradient(180deg, rgba(8, 15, 35, 0.97), rgba(3, 8, 24, 0.97));
    box-shadow: 0 32px 84px rgba(2, 6, 23, 0.38), inset 0 1px 0 rgba(255, 255, 255, 0.035);
  }

  :global(:root[data-theme='light']) .sr-sdk-terminal {
    background: rgba(15, 23, 42, 0.94);
  }

  .sr-terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(10, 16, 30, 0.78));
    color: #cbd5e1;
  }

  .sr-terminal-dots {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }

  .sr-terminal-dots span {
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 999px;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.18), 0 0 0 1px rgba(15, 23, 42, 0.18);
  }

  .sr-terminal-dots span:first-child {
    background: #ff5f57;
  }

  .sr-terminal-dots span:nth-child(2) {
    background: #febc2e;
  }

  .sr-terminal-dots span:nth-child(3) {
    background: #28c840;
  }

  .sr-terminal-bar strong {
    color: #9ca3af;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .sr-code-stack {
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
  }

  .sr-code-window {
    position: relative;
    overflow: hidden;
    border-radius: 1.05rem;
    background: rgba(4, 9, 22, 0.66);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.025);
  }

  .sr-code-window::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border: 1px solid rgba(148, 163, 184, 0.11);
    border-radius: inherit;
  }

  .sr-code-window:hover::before {
    border-color: rgba(34, 211, 238, 0.18);
  }

  .sr-copy-icon {
    position: absolute;
    top: 0.72rem;
    right: 0.72rem;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 0.7rem;
    background: rgba(15, 23, 42, 0.28);
    color: rgba(203, 213, 225, 0.62);
    opacity: 0.72;
    backdrop-filter: blur(10px);
    transition: opacity 180ms ease, transform 180ms ease, border-color 180ms ease, background 180ms ease, color 180ms ease;
  }

  .sr-copy-icon:hover {
    opacity: 1;
    transform: translateY(-1px);
    border-color: rgba(34, 211, 238, 0.26);
    background: rgba(15, 23, 42, 0.66);
    color: #e2e8f0;
  }

  .sr-copy-icon[data-copied='true'] {
    opacity: 1;
    border-color: rgba(45, 212, 191, 0.28);
    color: #99f6e4;
  }

  .sr-copy-icon[data-copy-failed='true'] {
    opacity: 1;
    border-color: rgba(248, 113, 113, 0.32);
    color: #fecaca;
  }

  .sr-copy-icon svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sr-code-stack pre {
    margin: 0;
    padding: 1.15rem 3.35rem 1.15rem 1.2rem;
    overflow-x: auto;
    color: #e2e8f0;
    font-size: clamp(0.82rem, 1.25vw, 0.96rem);
    line-height: 1.72;
  }

  .sr-code-window-install pre {
    padding-block: 1rem;
  }

  .sr-code-stack code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  .sr-code-prompt {
    color: #64748b;
  }

  .sr-code-command {
    color: #f8fafc;
    font-weight: 700;
  }

  .sr-code-keyword {
    color: #c084fc;
  }

  .sr-code-fn {
    color: #67e8f9;
  }

  .sr-code-method {
    color: #93c5fd;
  }

  .sr-code-string {
    color: #fde68a;
  }

  .sr-code-comment {
    color: #94a3b8;
  }

  .sr-code-output {
    display: inline-block;
    margin-top: 0.12rem;
    color: #5eead4;
    font-weight: 700;
  }

  @media (max-width: 1100px) {
