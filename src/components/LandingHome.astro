    border-radius: 1.25rem;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--sr-cyan) 8%, transparent), transparent 34%),
      linear-gradient(180deg, color-mix(in srgb, var(--sr-surface-strong) 92%, transparent), color-mix(in srgb, var(--sr-card) 86%, transparent));
    box-shadow: 0 20px 48px rgba(2, 6, 23, 0.16);
