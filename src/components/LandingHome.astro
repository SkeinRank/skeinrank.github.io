  .sr-metrics dt {
    margin: 0;
    color: var(--sr-muted);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sr-metrics dd {
    margin: 0.35rem 0 0;
    color: var(--sr-text);
    font-weight: 900;
  }

  .sr-hero-visual {
    position: relative;
    min-height: 33rem;
  }

  .sr-terminal-card,
  .sr-dashboard-card,
  .sr-feature-card,
  .sr-status-table,
  .sr-cta {
    border: 1px solid var(--sr-border);
    border-radius: var(--sr-radius-md);
    background: linear-gradient(145deg, var(--sr-surface-strong), var(--sr-card));
